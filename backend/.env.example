# LangSmith
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=nutrisnap

# FatSecret (optional)
FATSECRET_CLIENT_ID=
FATSECRET_CLIENT_SECRET=
