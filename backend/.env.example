ENV=development

# Telegram
BOT_TOKEN=
# For the Mini App to actually open from the bot, MINI_APP_URL must be https.
# In dev — run the `ngrok` service from docker-compose.dev.yml and paste the
# public URL it gives you (see http://localhost:4040). In prod — Vercel URL.
MINI_APP_URL=http://localhost:5173

# ngrok HTTPS tunnel for the Vite dev server (Mini App). Free token:
# https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# Database
DATABASE_URL=postgresql+asyncpg://nutrisnap:nutrisnap@postgres:5432/nutrisnap

# OpenAI
OPENAI_API_KEY=
VISION_MODEL=gpt-4o
TEXT_MODEL=gpt-4o-mini

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=foods

# LangSmith
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=nutrisnap

# FatSecret (optional)
FATSECRET_CLIENT_ID=
FATSECRET_CLIENT_SECRET=
